{
  "version": 1,
  "interfaces": {
    "LAN": "eth0",
    "WAN": "eth1"
  },
  "network": {
    "hostname": "nixwall",
    "addresses": {
      "LAN": "10.10.10.1/24",
      "WAN": "10.100.100.1/24"
    },
    "gateway": "10.100.100.254",
    "dns": ["10.100.100.10"]
  },
  "usersDefaults": {
    "initialPassword": "changeme"
  },
  "users": {
    "alice": { "wheel": true },
    "bob": { "groups": ["developers"] }
  },
  "dhcp": {
    "subnets": {
      "LAN": {
        "cidr": "10.10.10.0/24",
        "range": "10.10.10.50-10.10.10.150",
        "leaseSeconds": 86400
      }
    }
  },
  "firewall": {
    "rules": [
      {
        "name": "api",
        "from": "LAN",
        "to": "FW",
        "proto": "tcp",
        "ports": 8080,
        "action": "accept"
      }
    ]
  }
}
